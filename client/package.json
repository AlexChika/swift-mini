    "__": "",
    "lint:check": "eslint .",
    "types:check": "tsc --noEmit",
    "lint:fix": "eslint --fix",
    "format:fix": "prettier . --write",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@apollo/client": "^4.0.5",
    "@auth/prisma-adapter": "^2.10.0",
