    "@types/node": "^25.5.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "eslint": "^10.1.0",
    "prettier": "^3.6.2",
    "prisma": "6.19",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  }
