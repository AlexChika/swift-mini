    "@eslint-react/eslint-plugin": "^3.0.0",
    "@prisma/client": "6.19",
    "graphql": "^16.11.0",
    "graphql-ws": "^6.0.6",
    "next": "^16.2.1",
    "next-auth": "^5.0.0-beta.30",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.6.0",
    "react-virtuoso": "^4.14.0",
    "rxjs": "^7.8.2",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@chakra-ui/cli": "^3.16.1",
